# ============================================
# ML Platform Environment Configuration
# ============================================

# --------------------------------------------
# PostgreSQL Configuration
# --------------------------------------------
POSTGRES_USER=mlplatform
POSTGRES_PASSWORD=mlplatform_secret_key_2024
POSTGRES_DB=mlplatform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --------------------------------------------
# MongoDB Configuration
# --------------------------------------------
MONGO_USER=mlplatform
MONGO_PASSWORD=mlplatform_secret_key_2024
MONGO_DB=prediction_logs
MONGO_HOST=mongodb
MONGO_PORT=27017

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --------------------------------------------
# MinIO (S3-compatible) Configuration
# --------------------------------------------
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin_secret_key_2024
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=mlflow-artifacts

# --------------------------------------------
# MLflow Configuration
# --------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts
MLFLOW_PORT=5000

# --------------------------------------------
# Airflow Configuration
# --------------------------------------------
AIRFLOW_FERNET_KEY=your_fernet_key_here_generate_with_fernet
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin_secret_2024

# --------------------------------------------
# Grafana Configuration
# --------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_secret_2024

# --------------------------------------------
# Model Configuration
# --------------------------------------------
MODEL_NAME=churn-predictor
MODEL_STAGE=Production
MODEL_VERSION=latest

# --------------------------------------------
# Service URLs
# --------------------------------------------
DATA_SERVICE_URL=http://data-service:8000
FEATURE_SERVICE_URL=http://feature-service:8000
TRAINING_SERVICE_URL=http://training-service:8000
INFERENCE_API_URL=http://inference-api:8000
MONITORING_SERVICE_URL=http://monitoring-service:8000

# --------------------------------------------
# Alerting Configuration
# --------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_EMAIL=
SLACK_WEBHOOK_URL=

# --------------------------------------------
# Feature Store Configuration
# --------------------------------------------
FEATURE_STORE_ENABLED=true
FEATURE_REGISTRY_TABLE=feature_registry

# --------------------------------------------
# Training Configuration
# --------------------------------------------
TRAINING_PARALLEL_JOBS=4
OPTUNA_N_TRIALS=100
CROSS_VALIDATION_FOLDS=5
RANDOM_STATE=42

# --------------------------------------------
# Monitoring Configuration
# --------------------------------------------
DRIFT_DETECTION_WINDOW=1000
PERFORMANCE_THRESHOLD=0.05
DATA_DRIFT_THRESHOLD=0.1

# --------------------------------------------
# API Configuration
# --------------------------------------------
API_RATE_LIMIT=1000
API_TIMEOUT=30
BATCH_SIZE=1000

# --------------------------------------------
# Environment
# --------------------------------------------
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO